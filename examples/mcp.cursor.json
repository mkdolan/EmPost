{
  "mcpServers": {
    "emdash-drafts": {
      "command": "npx",
      "args": ["-y", "@emplugins/mcp-emdash-drafts"],
      "env": {
        "EMDASH_INGEST_URL": "https://YOUR_SITE/_emdash/api/plugins/empost-md-draft/ingest",
        "EMDASH_HMAC_SECRET": "REPLACE_WITH_PLUGIN_SECRET",
        "EMDASH_KEY_ID": "default"
      }
    }
  }
}
